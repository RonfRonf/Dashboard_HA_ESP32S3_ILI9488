wifi_ssid: "NomeRetaWiFi"
wifi_password: "passwordWiFi"

# Genera una chiave sicura con:
#   openssl rand -base64 32
api_key: "INCOLLA_QUI_LA_TUA_API_KEY_BASE64_32_BYTE"

ota_password: "una_password_sicura_per_ota"
